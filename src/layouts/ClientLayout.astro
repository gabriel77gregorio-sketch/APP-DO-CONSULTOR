---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  clientName?: string;
}

const { title, clientName = 'Minha Empresa' } = Astro.props;
---

<BaseLayout title={title ?? clientName}>
  <div class="min-h-screen" style="background: radial-gradient(ellipse at top left, rgba(124,58,237,0.08) 0%, transparent 50%), #0a0f1e;">
    
    <!-- Top bar -->
    <header class="sticky top-0 z-50 px-6 py-4 flex items-center justify-between" 
      style="background: rgba(10,15,30,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06);">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-xl flex items-center justify-center text-base" style="background: linear-gradient(135deg, #7c3aed, #6d28d9);">
          🗺️
        </div>
        <div>
          <span class="text-white font-bold text-sm">App do Consultor</span>
          <span class="text-brand-400 text-xs ml-2">· {clientName}</span>
        </div>
      </div>
      <a href="/logout" class="btn-ghost text-xs">Sair 🚪</a>
    </header>

    <!-- Content -->
    <main class="max-w-5xl mx-auto px-6 py-10">
      <slot />
    </main>
  </div>
</BaseLayout>
