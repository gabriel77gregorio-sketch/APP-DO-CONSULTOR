---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  clientName?: string;
}

const { title, clientName = 'Minha Empresa' } = Astro.props;
---

<BaseLayout title={title ?? clientName}>
  <div class="min-h-screen" style="background: radial-gradient(ellipse at top left, rgba(124,58,237,0.08) 0%, transparent 50%), #0a0f1e;">
    
    <!-- Top bar -->
    <header class="sticky top-0 z-50 px-4 md:px-6 py-3 md:py-4 flex items-center justify-between" 
      style="background: rgba(10,15,30,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06);">
      <div class="flex items-center gap-2 md:gap-3">
        <div class="w-8 h-8 rounded-xl flex items-center justify-center text-base flex-shrink-0" style="background: linear-gradient(135deg, #7c3aed, #6d28d9);">
          🗺️
        </div>
        <div class="flex flex-col md:flex-row md:items-center">
          <span class="text-white font-bold text-xs md:text-sm">App do Consultor</span>
          <span class="text-brand-400 text-[10px] md:text-xs md:ml-2 truncate max-w-[150px] md:max-w-none">· {clientName}</span>
        </div>
      </div>
      <a href="/logout" class="btn-ghost flex-shrink-0 text-xs px-2 py-1 md:px-3 md:py-1.5">Sair 🚪</a>
    </header>

    <!-- Content -->
    <main class="w-full max-w-5xl mx-auto px-4 md:px-6 py-6 md:py-10 overflow-x-hidden">
      <slot />
    </main>
  </div>
</BaseLayout>
