---
export const prerender = false;
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, supabaseAdmin, type Profile } from '../../lib/supabase';

// Verifica se é MASTER
const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';
const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';

const { data: profile } = await supabase.from('profiles').select('role').eq('id', userId).single();
if (!profile || profile.role !== 'master') return Astro.redirect('/dashboard');

// Lógica de POST: Criar novo consultor
let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = formData.get('name')?.toString() ?? '';
  const email = formData.get('email')?.toString() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  if (!supabaseAdmin) {
    errorMsg = 'Erro de configuração: SUPABASE_SERVICE_ROLE_KEY não encontrada no servidor.';
  } else {
    // 1. Cria usuário no Auth
    const { data: newUser, error: authError } = await supabaseAdmin.auth.admin.createUser({
      email,
      password,
      email_confirm: true,
      user_metadata: { full_name: name }
    });

    if (authError || !newUser.user) {
      errorMsg = authError?.message ?? 'Erro ao criar usuário.';
    } else {
      // 2. Garante que o profile é consultant (já é o default, mas garantimos)
      await supabaseAdmin.from('profiles').update({ role: 'consultant', full_name: name }).eq('id', newUser.user.id);
      successMsg = `Consultor ${name} criado com sucesso!`;
    }
  }
}

// Lista consultores
const { data: consultants = [] } = await supabase
  .from('profiles')
  .select('*')
  .eq('role', 'consultant')
  .order('created_at', { ascending: false });
---

<ConsultantLayout title="Gerenciar Consultores" activePage="master">
  <div class="p-8 animate-fade-in">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Gestão Master</h1>
        <p class="text-slate-400 text-sm mt-1">Gerencie seu time de consultores</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Formulário de Criação -->
      <div class="lg:col-span-1">
        <div class="glass p-6 sticky top-8">
          <h2 class="text-lg font-bold text-white mb-4">Novo Consultor</h2>
          
          {successMsg && <div class="mb-4 p-3 bg-green-500/10 border border-green-500/20 text-green-400 text-xs rounded-xl">✅ {successMsg}</div>}
          {errorMsg && <div class="mb-4 p-3 bg-red-500/10 border border-red-500/20 text-red-400 text-xs rounded-xl">⚠️ {errorMsg}</div>}

          <form method="POST" class="space-y-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">Nome Completo</label>
              <input type="text" name="name" required class="input py-2.5" placeholder="João Silva" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">E-mail de Acesso</label>
              <input type="email" name="email" required class="input py-2.5" placeholder="joao@empresa.com" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">Senha Inicial</label>
              <input type="password" name="password" required class="input py-2.5" placeholder="••••••••" />
              <p class="text-[10px] text-slate-600 mt-1.5">Mínimo 6 caracteres</p>
            </div>
            <button type="submit" class="btn-primary w-full justify-center py-3">Criar Acesso</button>
          </form>
        </div>
      </div>

      <!-- Lista de Consultores -->
      <div class="lg:col-span-2">
        <div class="glass p-6">
          <h2 class="text-lg font-bold text-white mb-4">Consultores Ativos ({consultants.length})</h2>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-white/5">
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase">Consultor</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase">Acesso</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase text-right">Cadastrado em</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {consultants.map((c: any) => (
                  <tr>
                    <td class="py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-brand-400/20 text-brand-400 flex items-center justify-center text-xs font-bold">
                          {c.full_name?.charAt(0)}
                        </div>
                        <span class="text-white text-sm font-medium">{c.full_name}</span>
                      </div>
                    </td>
                    <td class="py-4 text-slate-400 text-sm">{c.email || '—'}</td>
                    <td class="py-4 text-slate-500 text-xs text-right">
                      {new Date(c.created_at).toLocaleDateString('pt-BR')}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</ConsultantLayout>
