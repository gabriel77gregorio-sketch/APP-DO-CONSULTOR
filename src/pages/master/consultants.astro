---
export const prerender = false;
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, supabaseAdmin, type Profile } from '../../lib/supabase';

// Usa admin para ignorar RLS em todas as queries
const db = supabaseAdmin ?? supabase;

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';
const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';

const { data: profile } = await db.from('profiles').select('role').eq('id', userId).single();
if (!profile || profile.role !== 'master') return Astro.redirect('/dashboard');

// Lógica de POST: Criar novo consultor
let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create') {
    const name = formData.get('name')?.toString().trim() ?? '';
    const email = formData.get('email')?.toString().trim() ?? '';
    const password = formData.get('password')?.toString() ?? '';

    if (!name || !email || !password) {
      errorMsg = 'Preencha todos os campos.';
    } else if (!supabaseAdmin) {
      errorMsg = 'Erro de configuração: SUPABASE_SERVICE_ROLE_KEY não encontrada.';
    } else {
      const { data: newUser, error: authError } = await supabaseAdmin.auth.admin.createUser({
        email,
        password,
        email_confirm: true,
        user_metadata: { full_name: name }
      });

      if (authError || !newUser?.user) {
        errorMsg = authError?.message ?? 'Erro ao criar usuário.';
      } else {
        await supabaseAdmin.from('profiles').upsert({
          id: newUser.user.id,
          full_name: name,
          role: 'consultant',
          avatar_url: null,
        });
        successMsg = `Consultor ${name} criado com sucesso!`;
      }
    }
  } else if (action === 'delete') {
    const targetId = formData.get('target_id')?.toString();
    if (targetId && supabaseAdmin) {
      // Remove todos os clientes e dados do consultor
      const { data: consultantClients } = await supabaseAdmin.from('clients').select('id').eq('consultant_id', targetId);
      if (consultantClients) {
        for (const c of consultantClients) {
          await supabaseAdmin.from('tasks').delete().eq('client_id', c.id);
          await supabaseAdmin.from('roadmap_steps').delete().eq('client_id', c.id);
          await supabaseAdmin.from('documents').delete().eq('client_id', c.id);
          await supabaseAdmin.from('clients').delete().eq('id', c.id);
        }
      }
      await supabaseAdmin.from('profiles').delete().eq('id', targetId);
      await supabaseAdmin.auth.admin.deleteUser(targetId);
      successMsg = 'Consultor removido com sucesso.';
    }
  }
}

// Lista consultores cruzando Auth + profiles
let consultants: any[] = [];
if (supabaseAdmin) {
  const [{ data: { users: authUsers } }, { data: profiles }] = await Promise.all([
    supabaseAdmin.auth.admin.listUsers(),
    supabaseAdmin.from('profiles').select('*').eq('role', 'consultant'),
  ]);
  
  consultants = (profiles ?? []).map((p: any) => {
    const authUser = authUsers.find((u: any) => u.id === p.id);
    return { ...p, email: authUser?.email ?? '—', last_sign_in: authUser?.last_sign_in_at };
  }).sort((a: any, b: any) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
}
---

<ConsultantLayout title="Gestão Master" activePage="master">
  <div class="p-4 md:p-8 animate-fade-in max-w-[100vw]">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 md:mb-8 gap-4 sm:gap-0">
      <div>
        <h1 class="text-2xl font-bold text-white">Gestão Master</h1>
        <p class="text-slate-400 text-sm mt-1">Gerencie seu time de consultores</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
      <!-- Formulário de Criação -->
      <div class="lg:col-span-1">
        <div class="glass p-6 sticky top-8">
          <h2 class="text-lg font-bold text-white mb-4">Novo Consultor</h2>
          
          {successMsg && <div class="mb-4 p-3 bg-green-500/10 border border-green-500/20 text-green-400 text-xs rounded-xl">✅ {successMsg}</div>}
          {errorMsg && <div class="mb-4 p-3 bg-red-500/10 border border-red-500/20 text-red-400 text-xs rounded-xl">⚠️ {errorMsg}</div>}

          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="create" />
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">Nome Completo</label>
              <input type="text" name="name" required class="input py-2.5" placeholder="João Silva" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">E-mail de Acesso</label>
              <input type="email" name="email" required class="input py-2.5" placeholder="joao@empresa.com" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">Senha Inicial</label>
              <input type="password" name="password" required minlength="6" class="input py-2.5" placeholder="••••••••" />
              <p class="text-[10px] text-slate-600 mt-1.5">Mínimo 6 caracteres</p>
            </div>
            <button type="submit" class="btn-primary w-full justify-center py-3">Criar Acesso</button>
          </form>
        </div>
      </div>

      <!-- Lista de Consultores -->
      <div class="lg:col-span-2">
        <div class="glass p-6">
          <h2 class="text-lg font-bold text-white mb-4">Consultores Ativos ({consultants.length})</h2>
          
          {consultants.length === 0 ? (
            <div class="text-center py-12">
              <p class="text-4xl mb-3">👥</p>
              <p class="text-slate-500 text-sm">Nenhum consultor cadastrado ainda</p>
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-white/5">
                    <th class="pb-3 text-xs font-semibold text-slate-500 uppercase">Consultor</th>
                    <th class="pb-3 text-xs font-semibold text-slate-500 uppercase">E-mail</th>
                    <th class="pb-3 text-xs font-semibold text-slate-500 uppercase text-right">Cadastrado em</th>
                    <th class="pb-3 text-xs font-semibold text-slate-500 uppercase text-right">Ação</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                  {consultants.map((c: any) => (
                    <tr class="group">
                      <td class="py-4">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-full bg-brand-400/20 text-brand-400 flex items-center justify-center text-xs font-bold">
                            {(c.full_name ?? c.email)?.charAt(0)?.toUpperCase()}
                          </div>
                          <span class="text-white text-sm font-medium">{c.full_name || '—'}</span>
                        </div>
                      </td>
                      <td class="py-4 text-slate-400 text-sm">{c.email}</td>
                      <td class="py-4 text-slate-500 text-xs text-right">
                        {new Date(c.created_at).toLocaleDateString('pt-BR')}
                      </td>
                      <td class="py-4 text-right">
                        <form method="POST" onsubmit="return confirm('Remover este consultor? Todos os dados serão excluídos.')">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="target_id" value={c.id} />
                          <button type="submit" class="text-slate-600 hover:text-red-400 transition-colors text-sm" title="Remover consultor">
                            🗑️
                          </button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</ConsultantLayout>
