---
export const prerender = false;
import ClientLayout from '../../layouts/ClientLayout.astro';
import RoadmapTimeline from '../../components/client/RoadmapTimeline';
import { supabase, calcProgress, type RoadmapStep, type Task, type Document } from '../../lib/supabase';

const { clientId } = Astro.params;
if (!clientId) return Astro.redirect('/login');

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userEmail = authData?.session?.user?.email ?? '';

// Verifica que o cliente tem acesso ao roadmap solicitado
const { data: client, error } = await supabase
  .from('clients')
  .select('*')
  .eq('id', clientId)
  .single();

if (error || !client) return Astro.redirect('/login');

// Verifica permissão: é o consultor dono OU é o cliente com esse email
const userId = authData?.session?.user?.id ?? '';
const isConsultant = client.consultant_id === userId;
const isClient = client.client_email === userEmail;

if (!isConsultant && !isClient) return Astro.redirect('/login');

// Busca dados
const [{ data: steps = [] }, { data: tasks = [] }, { data: documents = [] }] = await Promise.all([
  supabase.from('roadmap_steps').select('*').eq('client_id', clientId).order('step_number'),
  supabase.from('tasks').select('*').eq('client_id', clientId).order('created_at'),
  supabase.from('documents').select('*').eq('client_id', clientId).order('uploaded_at', { ascending: false }),
]);

const progress = calcProgress((steps ?? []) as RoadmapStep[]);
---

<ClientLayout title={`Roadmap · ${client.name}`} clientName={client.name}>
  <RoadmapTimeline
    client:load
    steps={(steps ?? []) as RoadmapStep[]}
    tasks={(tasks ?? []) as Task[]}
    documents={(documents ?? []) as Document[]}
    clientName={client.name}
    clientId={clientId}
    progress={progress}
  />
</ClientLayout>
