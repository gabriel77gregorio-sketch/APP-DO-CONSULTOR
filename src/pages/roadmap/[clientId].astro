---
export const prerender = false;
import ClientLayout from '../../layouts/ClientLayout.astro';
import RoadmapTimeline from '../../components/client/RoadmapTimeline';
import { supabase, supabaseAdmin, calcProgress, type RoadmapStep, type Task, type Document } from '../../lib/supabase';

const { clientId } = Astro.params;
if (!clientId) return Astro.redirect('/login');

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';
const userEmail = authData?.session?.user?.email ?? '';

// Usa admin para buscar o cliente (ignora RLS)
const db = supabaseAdmin ?? supabase;

const { data: client, error } = await db
  .from('clients')
  .select('*')
  .eq('id', clientId)
  .single();

if (error || !client) return Astro.redirect('/login');

// Verifica permissão: é o consultor dono, é o master ou é o cliente com esse email
const { data: userProfile } = await db.from('profiles').select('role').eq('id', userId).single();
const isMaster = userProfile?.role === 'master';
const isConsultant = client.consultant_id === userId;
const isClient = client.client_email === userEmail;

if (!isMaster && !isConsultant && !isClient) return Astro.redirect('/login');

// Busca dados em paralelo
const [{ data: steps = [] }, { data: tasks = [] }, { data: documents = [] }] = await Promise.all([
  db.from('roadmap_steps').select('*').eq('client_id', clientId).order('step_number'),
  db.from('tasks').select('*').eq('client_id', clientId).order('created_at'),
  db.from('documents').select('*').eq('client_id', clientId).order('uploaded_at', { ascending: false }),
]);

const progress = calcProgress((steps ?? []) as RoadmapStep[]);

let finalLogoUrl = client.logo_url;
if (finalLogoUrl && !finalLogoUrl.startsWith('http') && !finalLogoUrl.startsWith('data:')) {
    const { data } = await db.storage.from('vault').createSignedUrl(finalLogoUrl, 3600); // 1hr
    if (data?.signedUrl) {
        finalLogoUrl = data.signedUrl;
    }
}
---

<ClientLayout title={`Roadmap · ${client.name}`} clientName={client.name}>
  <RoadmapTimeline
    client:load
    steps={(steps ?? []) as RoadmapStep[]}
    tasks={(tasks ?? []) as Task[]}
    documents={(documents ?? []) as Document[]}
    clientName={client.name}
    clientId={clientId}
    progress={progress}
    accessToken={accessToken}
    refreshToken={refreshToken}
    roadmapTitle={client.roadmap_title}
    roadmapSubtitle={client.roadmap_subtitle}
    primaryColor={client.primary_color}
    logoUrl={finalLogoUrl}
  />
</ClientLayout>
