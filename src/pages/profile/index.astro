---
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, supabaseAdmin } from '../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData, error: authErr } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (authErr || !authData?.session?.user) return Astro.redirect('/login');

const user = authData.session.user;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

let currentProfile = profile ?? {};

let message = '';
let isError = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'update_profile') {
    const full_name = formData.get('full_name')?.toString() || '';
    const reply_to_email = formData.get('reply_to_email')?.toString() || null;
    if (full_name) {
      // Usar db (supabaseAdmin) para contornar qualquer policy de RLS que bloqueie consultores
      const db = supabaseAdmin ?? supabase;
      const { error } = await db.from('profiles').update({ full_name, reply_to_email }).eq('id', user.id);
      if (error) {
        message = 'Erro ao atualizar dados: ' + error.message;
        isError = true;
      } else {
        message = 'Perfil atualizado com sucesso!';
        currentProfile.full_name = full_name; // Atualiza a variável local para refletir na tela
        currentProfile.reply_to_email = reply_to_email;
      }
    }
  } else if (action === 'update_password') {
    const new_password = formData.get('new_password')?.toString() || '';
    const confirm_password = formData.get('confirm_password')?.toString() || '';

    if (!new_password || new_password.length < 6) {
      message = 'A nova senha deve ter no mínimo 6 caracteres.';
      isError = true;
    } else if (new_password !== confirm_password) {
      message = 'As senhas não coincidem.';
      isError = true;
    } else {
      const { error } = await supabase.auth.updateUser({ password: new_password });
      if (error) {
        message = 'Erro ao atualizar senha: ' + error.message;
        isError = true;
      } else {
        message = 'Senha alterada com sucesso!';
      }
    }
  }
}

// Recarrega os dados caso tenha atualizado
---

<ConsultantLayout title="Meu Perfil" activePage="profile">
  <div class="p-4 md:p-8 animate-fade-in max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-6 md:mb-8">
      <h1 class="text-2xl font-bold text-slate-800">Meu Perfil</h1>
      <p class="text-slate-500 text-sm mt-1">Gerencie seus dados e credenciais de acesso.</p>
    </div>

    {message && (
      <div class={`mb-6 p-4 rounded-xl text-sm font-medium ${isError ? 'bg-red-500/10 text-red-500 border border-red-500/20' : 'bg-green-50 border border-green-200 text-green-700'}`}>
        <span>{isError ? '⚠️ ' : '✅ '}{message}</span>
      </div>
    )}

    <div class="space-y-6">
      <!-- Info Básica -->
      <div class="glass p-6 md:p-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xl">🧑‍💼</span>
          <h2 class="text-slate-800 font-bold text-lg">Informações Pessoais</h2>
        </div>
        
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="update_profile" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">E-mail (Login)</label>
              <input type="text" value={user.email} disabled class="input opacity-50 cursor-not-allowed w-full" />
              <p class="text-xs text-slate-500 mt-1">O e-mail não pode ser alterado por aqui.</p>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nome Completo</label>
              <input type="text" name="full_name" required value={currentProfile.full_name || ''} class="input w-full focus:border-brand-500" />
              <p class="text-[10px] text-slate-500 mt-1">Este nome aparecerá como remetente nos e-mails.</p>
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">E-mail de Resposta (Reply-To)</label>
            <input type="email" name="reply_to_email" placeholder="contato@suaconsultoria.com" value={currentProfile.reply_to_email || ''} class="input w-full focus:border-brand-500" />
            <p class="text-[10px] text-slate-500 mt-1">Se preenchido, os clientes enviarão respostas para este destino. Do contrário, o padrão da plataforma é usado.</p>
          </div>
          
          <div class="pt-4 border-t border-slate-200 flex justify-end">
            <button type="submit" class="btn-primary">Salvar Dados</button>
          </div>
        </form>
      </div>

      <!-- Senha -->
      <div class="glass p-6 md:p-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xl">🔒</span>
          <h2 class="text-slate-800 font-bold text-lg">Segurança da Conta</h2>
        </div>
        
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="update_password" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nova Senha</label>
              <input type="password" name="new_password" required minlength="6" class="input w-full focus:border-brand-500" placeholder="Mínimo 6 caracteres" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Confirmar Senha</label>
              <input type="password" name="confirm_password" required minlength="6" class="input w-full focus:border-brand-500" placeholder="Mínimo 6 caracteres" />
            </div>
          </div>
          
          <div class="pt-4 border-t border-slate-200 flex justify-end">
            <button type="submit" class="glass-hover text-brand-400 px-5 py-2.5 rounded-xl font-bold transition-colors">Atualizar Senha</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</ConsultantLayout>
