---
export const prerender = false;
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, supabaseAdmin, calcProgress, type Client, type RoadmapStep } from '../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';

// Usa admin para ignorar RLS
const db = supabaseAdmin ?? supabase;

// Handle POST: adicionar novo cliente
let formError = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const name = fd.get('name')?.toString().trim() ?? '';
  const clientEmail = fd.get('client_email')?.toString().trim() ?? '';
  const sector = fd.get('sector')?.toString().trim() || null;
  const tempPassword = fd.get('password')?.toString() ?? '';

  if (!name || !clientEmail || !tempPassword) {
    formError = 'Preencha todos os campos obrigatórios.';
  } else if (!supabaseAdmin) {
    formError = 'Erro crítico: Chave administrativa não configurada no servidor.';
  } else {
    try {
      // 1. Cria usuário no Supabase Auth (Admin API)
      const { data: newUser, error: authError } = await supabaseAdmin.auth.admin.createUser({
        email: clientEmail,
        password: tempPassword,
        email_confirm: true,
        user_metadata: { full_name: name }
      });

      if (authError || !newUser?.user) {
        formError = authError?.message ?? 'Erro ao criar conta do cliente.';
      } else {
        // 2. Cria registro do cliente no banco (com admin para ignorar RLS)
        const { data: client, error: clientError } = await supabaseAdmin
          .from('clients')
          .insert({
            consultant_id: userId,
            name,
            client_email: clientEmail,
            sector,
          })
          .select()
          .single();

        if (clientError || !client) {
          // Rollback: remove o usuário auth criado
          await supabaseAdmin.auth.admin.deleteUser(newUser.user.id);
          formError = clientError?.message ?? 'Erro ao salvar dados do cliente.';
        } else {
          // 3. Atualiza o perfil com role 'client' e nome correto
          await supabaseAdmin.from('profiles').upsert({
            id: newUser.user.id,
            full_name: name,
            role: 'client',
            avatar_url: null,
          });

          // 4. Cria os 12 roadmap_steps automaticamente para o cliente
          const roadmapTemplate = [
            { step: 1, month: 'Mês 1', title: 'Diagnóstico e Alinhamento', desc: 'Mapeamento da situação atual e definição de objetivos', checks: ['Cultura organizacional mapeada', 'Principais dores identificadas', 'Metas definidas e alinhadas'] },
            { step: 2, month: 'Mês 1', title: 'Estrutura de RH', desc: 'Análise e organização da estrutura de recursos humanos', checks: ['Organograma revisado', 'Funções e responsabilidades claras', 'Gaps de competência identificados'] },
            { step: 3, month: 'Mês 2', title: 'Atração e Recrutamento', desc: 'Estratégia para atrair os melhores talentos', checks: ['Employer branding definido', 'Processo seletivo estruturado', 'Job descriptions revisados'] },
            { step: 4, month: 'Mês 2', title: 'Onboarding', desc: 'Programa de integração de novos colaboradores', checks: ['Processo de onboarding criado', 'Materiais de boas-vindas prontos', 'Buddy system implementado'] },
            { step: 5, month: 'Mês 3', title: 'Avaliação de Desempenho', desc: 'Sistema de avaliação e feedback contínuo', checks: ['Modelo de avaliação escolhido', 'Critérios e pesos definidos', 'Ciclo de avaliação planejado'] },
            { step: 6, month: 'Mês 3', title: 'Remuneração e Benefícios', desc: 'Política de remuneração competitiva e atrativa', checks: ['Pesquisa salarial realizada', 'Política de benefícios revisada', 'Plano de cargos e salários estruturado'] },
            { step: 7, month: 'Mês 4', title: 'Treinamento e Desenvolvimento', desc: 'Plano de capacitação para evolução das equipes', checks: ['Matriz de treinamentos criada', 'Plano de PDI implementado', 'Trilhas de aprendizado definidas'] },
            { step: 8, month: 'Mês 4', title: 'Clima e Engajamento', desc: 'Diagnóstico e plano de ação para engajamento', checks: ['Pesquisa de clima realizada', 'Principais pontos analisados', 'Plano de ação elaborado'] },
            { step: 9, month: 'Mês 5', title: 'Liderança e Cultura', desc: 'Desenvolvimento de líderes e fortalecimento da cultura', checks: ['Perfil de liderança definido', 'Programa de desenvolvimento lançado', 'Valores organizacionais comunicados'] },
            { step: 10, month: 'Mês 5', title: 'Processos e Compliance', desc: 'Regularização de processos e conformidade legal', checks: ['Processos mapeados e documentados', 'Conformidade legal verificada', 'Políticas internas atualizadas'] },
            { step: 11, month: 'Mês 6', title: 'Indicadores de RH (KPIs)', desc: 'Implementação de métricas e dashboards de gestão', checks: ['KPIs de RH definidos', 'Dashboard de métricas criado', 'Rotina de análise estabelecida'] },
            { step: 12, month: 'Mês 6', title: 'Revisão e Plano de Continuidade', desc: 'Consolidação dos resultados e próximos passos', checks: ['Resultados consolidados', 'Próximos passos definidos', 'Autonomia da equipe garantida'] },
          ];

          const stepsToInsert = roadmapTemplate.map((item, i) => ({
            client_id: client.id,
            step_number: item.step,
            title: item.title,
            description: item.desc,
            month_label: item.month,
            status: i === 0 ? 'current' : 'locked',
            notes: null,
            checkmarks: item.checks.map(label => ({ label, checked: false })),
            delivery_url: null,
          }));

          await supabaseAdmin.from('roadmap_steps').insert(stepsToInsert);

          return Astro.redirect('/clients');
        }
      }
    } catch (e: any) {
      formError = 'Erro inesperado: ' + e.message;
    }
  }
}

const { data: profile } = await db.from('profiles').select('role').eq('id', userId).single();

// Lista clientes (ou todos se for MASTER)
let query = db.from('clients').select('*');
if (profile?.role !== 'master') {
  query = query.eq('consultant_id', userId);
}
const { data: clients = [] } = await query.order('created_at', { ascending: false });

const clientsWithProgress = await Promise.all(
  (clients ?? []).map(async (client: Client) => {
    const { data: steps = [] } = await db
      .from('roadmap_steps')
      .select('status, step_number, title')
      .eq('client_id', client.id);
    const progress = calcProgress((steps ?? []) as RoadmapStep[]);
    const current = (steps ?? []).find((s: any) => s.status === 'current');
    return { ...client, progress, currentStep: current?.title ?? '—' };
  })
);
---

<ConsultantLayout title="Meus Clientes" activePage="clients">
  <div class="p-8 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Meus Clientes</h1>
        <p class="text-slate-400 text-sm mt-1">{clientsWithProgress.length} empresa{clientsWithProgress.length !== 1 ? 's' : ''} na carteira</p>
      </div>
      <button
        onclick="document.getElementById('add-client-modal').classList.remove('hidden')"
        class="btn-primary"
        id="open-add-modal"
      >
        <span>+</span> Adicionar Cliente
      </button>
    </div>

    <!-- Grid de clientes -->
    {clientsWithProgress.length === 0 ? (
      <div class="glass p-16 text-center">
        <p class="text-5xl mb-4">🏢</p>
        <h3 class="text-white font-bold text-lg mb-2">Carteira vazia</h3>
        <p class="text-slate-400 text-sm mb-6">Adicione seu primeiro cliente e os 12 encontros serão criados automaticamente!</p>
        <button onclick="document.getElementById('add-client-modal').classList.remove('hidden')" class="btn-primary">
          Adicionar Primeiro Cliente
        </button>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        {clientsWithProgress.map((client) => (
          <a href={`/clients/${client.id}`} class="glass-hover p-6 block group">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center text-xl font-bold text-white flex-shrink-0"
                style="background: linear-gradient(135deg, rgba(124,58,237,0.5), rgba(109,40,217,0.7));">
                {client.name.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-white font-semibold truncate">{client.name}</h3>
                {client.sector && <p class="text-slate-500 text-xs mt-0.5">{client.sector}</p>}
                <p class="text-slate-400 text-xs mt-1 truncate">Em: {client.currentStep}</p>
              </div>
              <span class="text-slate-600 group-hover:text-brand-400 transition-colors">→</span>
            </div>

            <!-- Barra de progresso -->
            <div class="flex items-center gap-3">
              <div class="progress-bar flex-1">
                <div class="progress-fill" style={`width: ${client.progress}%`}></div>
              </div>
              <span class="text-xs font-bold text-brand-400">{client.progress}%</span>
            </div>
            <p class="text-slate-600 text-xs mt-2">
              Desde {new Date(client.created_at).toLocaleDateString('pt-BR')}
            </p>
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- Modal Adicionar Cliente -->
  <div id="add-client-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
    style="background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);">
    <div class="glass w-full max-w-md animate-slide-up" style="border-color: rgba(124,58,237,0.3);">
      <div class="p-6 border-b border-white/5 flex items-center justify-between">
        <h2 class="text-white font-bold text-lg">Novo Cliente</h2>
        <button
          onclick="document.getElementById('add-client-modal').classList.add('hidden')"
          class="text-slate-400 hover:text-white transition-colors text-xl leading-none"
          id="close-modal-btn"
        >✕</button>
      </div>
      <form method="POST" class="p-6 space-y-4" id="add-client-form">
        {formError && (
          <div class="px-4 py-3 rounded-xl text-red-400 text-sm" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);">
            ⚠️ {formError}
          </div>
        )}
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Nome da Empresa *</label>
          <input type="text" name="name" required class="input" placeholder="Ex: Tech Solutions Ltda" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Segmento</label>
          <input type="text" name="sector" class="input" placeholder="Ex: Tecnologia, Varejo, Saúde..." />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">E-mail do Cliente *</label>
          <input type="email" name="client_email" required class="input" placeholder="rh@empresa.com.br" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Senha Temporária *</label>
          <input type="password" name="password" required minlength="6" class="input" placeholder="Mínimo 6 caracteres" />
          <p class="text-slate-600 text-xs mt-1">O cliente usará esta senha para acessar o roadmap</p>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button"
            onclick="document.getElementById('add-client-modal').classList.add('hidden')"
            class="btn-ghost flex-1 justify-center">
            Cancelar
          </button>
          <button type="submit" class="btn-primary flex-1 justify-center" id="submit-client-btn">
            Criar Cliente ✓
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Fecha modal ao clicar no fundo
    const modal = document.getElementById('add-client-modal');
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });

    // Abre modal se houve erro (para mostrar a mensagem)
    const hasError = document.querySelector('#add-client-form .text-red-400');
    if (hasError) {
      modal?.classList.remove('hidden');
    }

    // Feedback de carregamento ao submeter
    const form = document.getElementById('add-client-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-client-btn') as HTMLButtonElement;
    form?.addEventListener('submit', () => {
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Criando...';
      }
    });
  </script>
</ConsultantLayout>
