---
export const prerender = false;
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, calcProgress, type Client, type RoadmapStep } from '../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';

// Handle POST: adicionar novo cliente
let formError = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const name = fd.get('name')?.toString().trim() ?? '';
  const clientEmail = fd.get('client_email')?.toString().trim() ?? '';
  const sector = fd.get('sector')?.toString().trim() ?? null;
  const tempPassword = fd.get('password')?.toString() ?? '';

  if (!name || !clientEmail || !tempPassword) {
    formError = 'Preencha todos os campos obrigatórios.';
  } else {
    // Cria usuário no Supabase Auth para o cliente
    const { data: newUser, error: authError } = await supabase.auth.admin?.createUser({
      email: clientEmail,
      password: tempPassword,
      email_confirm: true,
    }) ?? { data: null, error: new Error('Admin API não disponível no lado do cliente') };

    if (authError || !newUser?.user) { // Check newUser.user for null/undefined
      formError = authError?.message ?? 'Erro ao criar conta do cliente.';
    } else {
      // 2. Cria record do cliente no banco
      const { data: client, error: clientError } = await supabase
        .from('clients')
        .insert({
          consultant_id: userId,
          name,
          client_email: clientEmail, // Changed 'email' to 'clientEmail'
          sector,
        })
        .select()
        .single();

      if (clientError || !client) {
        formError = clientError?.message ?? 'Erro ao salvar dados do cliente.';
      } else {
        // 3. Atualiza o perfil recém-criado (pelo trigger) com role 'client'
        // Usamos o supabaseAdmin para garantir que o Master/Consultor tenha permissão de mudar o perfil
        if (supabaseAdmin) {
          await supabaseAdmin.from('profiles').update({ role: 'client', full_name: name }).eq('id', newUser.user.id);
        }
        successMsg = `Cliente ${name} cadastrado com sucesso!`;
        return Astro.redirect('/clients'); // Recarrega
      }
    }
  }
}

const { data: profile } = await supabase.from('profiles').select('role').eq('id', userId).single();

// Lista clientes (ou todos se for MASTER)
let query = supabase.from('clients').select('*');
if (profile?.role !== 'master') {
  query = query.eq('consultant_id', userId);
}
const { data: clients = [] } = await query.order('created_at', { ascending: false });

const clientsWithProgress = await Promise.all(
  (clients ?? []).map(async (client: Client) => {
    const { data: steps = [] } = await supabase
      .from('roadmap_steps')
      .select('status, step_number, title')
      .eq('client_id', client.id);
    const progress = calcProgress((steps ?? []) as RoadmapStep[]);
    const current = (steps ?? []).find((s: any) => s.status === 'current');
    return { ...client, progress, currentStep: current?.title ?? '—' };
  })
);
---

<ConsultantLayout title="Meus Clientes" activePage="clients">
  <div class="p-8 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Meus Clientes</h1>
        <p class="text-slate-400 text-sm mt-1">{clientsWithProgress.length} empresa{clientsWithProgress.length !== 1 ? 's' : ''} na carteira</p>
      </div>
      <button
        onclick="document.getElementById('add-client-modal').classList.remove('hidden')"
        class="btn-primary"
        id="open-add-modal"
      >
        <span>+</span> Adicionar Cliente
      </button>
    </div>

    <!-- Grid de clientes -->
    {clientsWithProgress.length === 0 ? (
      <div class="glass p-16 text-center">
        <p class="text-5xl mb-4">🏢</p>
        <h3 class="text-white font-bold text-lg mb-2">Carteira vazia</h3>
        <p class="text-slate-400 text-sm mb-6">Adicione seu primeiro cliente e o roadmap de 12 encontros será criado automaticamente!</p>
        <button onclick="document.getElementById('add-client-modal').classList.remove('hidden')" class="btn-primary">
          Adicionar Primeiro Cliente
        </button>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        {clientsWithProgress.map((client) => (
          <a href={`/clients/${client.id}`} class="glass-hover p-6 block group">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center text-xl font-bold text-white flex-shrink-0"
                style="background: linear-gradient(135deg, rgba(124,58,237,0.5), rgba(109,40,217,0.7));">
                {client.name.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-white font-semibold truncate">{client.name}</h3>
                {client.sector && <p class="text-slate-500 text-xs mt-0.5">{client.sector}</p>}
                <p class="text-slate-400 text-xs mt-1 truncate">Em: {client.currentStep}</p>
              </div>
              <span class="text-slate-600 group-hover:text-brand-400 transition-colors">→</span>
            </div>

            <!-- Barra de progresso -->
            <div class="flex items-center gap-3">
              <div class="progress-bar flex-1">
                <div class="progress-fill" style={`width: ${client.progress}%`}></div>
              </div>
              <span class="text-xs font-bold text-brand-400">{client.progress}%</span>
            </div>
            <p class="text-slate-600 text-xs mt-2">
              Desde {new Date(client.created_at).toLocaleDateString('pt-BR')}
            </p>
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- Modal Adicionar Cliente -->
  <div id="add-client-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
    style="background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);">
    <div class="glass w-full max-w-md animate-slide-up" style="border-color: rgba(124,58,237,0.3);">
      <div class="p-6 border-b border-white/5 flex items-center justify-between">
        <h2 class="text-white font-bold text-lg">Novo Cliente</h2>
        <button
          onclick="document.getElementById('add-client-modal').classList.add('hidden')"
          class="text-slate-400 hover:text-white transition-colors text-xl leading-none"
        >✕</button>
      </div>
      <form method="POST" class="p-6 space-y-4">
        {formError && (
          <div class="px-4 py-3 rounded-xl text-red-400 text-sm" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);">
            ⚠️ {formError}
          </div>
        )}
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Nome da Empresa *</label>
          <input type="text" name="name" required class="input" placeholder="Ex: Tech Solutions Ltda" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Segmento</label>
          <input type="text" name="sector" class="input" placeholder="Ex: Tecnologia, Varejo, Saúde..." />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">E-mail do Cliente *</label>
          <input type="email" name="client_email" required class="input" placeholder="rh@empresa.com.br" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Senha Temporária *</label>
          <input type="password" name="password" required minlength="6" class="input" placeholder="Mínimo 6 caracteres" />
          <p class="text-slate-600 text-xs mt-1">O cliente usará esta senha para acessar o roadmap</p>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button"
            onclick="document.getElementById('add-client-modal').classList.add('hidden')"
            class="btn-ghost flex-1 justify-center">
            Cancelar
          </button>
          <button type="submit" class="btn-primary flex-1 justify-center">
            Criar Cliente ✓
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Fecha modal ao clicar no fundo
    const modal = document.getElementById('add-client-modal');
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });
  </script>
</ConsultantLayout>
