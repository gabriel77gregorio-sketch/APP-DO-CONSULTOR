---
export const prerender = false;
import ConsultantLayout from '../../layouts/ConsultantLayout.astro';
import { supabase, supabaseAdmin, calcProgress, type Client, type RoadmapStep, type Task, type Document } from '../../lib/supabase';
import StepEditor from '../../components/consultant/StepEditor';
import VaultUploader from '../../components/consultant/VaultUploader';

const { id } = Astro.params;
if (!id) return Astro.redirect('/clients');

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? '';
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value ?? '';

const { data: authData } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
const userId = authData?.session?.user?.id ?? '';

// Usa admin para ignorar RLS
const db = supabaseAdmin ?? supabase;

// Busca o perfil do usuário para verificar se é master
const { data: profile } = await db.from('profiles').select('role').eq('id', userId).single();

// Busca o cliente — master pode ver qualquer cliente, consultor só os seus
let clientQuery = db.from('clients').select('*').eq('id', id);
if (profile?.role !== 'master') {
  clientQuery = clientQuery.eq('consultant_id', userId);
}
const { data: client, error: clientError } = await clientQuery.single();

if (clientError || !client) return Astro.redirect('/clients');

// Processa ações de upload e delete ANTES de buscar dados
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'delete-file') {
    const fileId = formData.get('file-id')?.toString();
    const filePath = formData.get('file-path')?.toString();
    if (fileId && filePath) {
      await db.storage.from('vault').remove([filePath]);
      await db.from('documents').delete().eq('id', fileId);
    }
  } else if (action === 'delete-client') {
    // Deleta cliente e todos os dados relacionados
    await db.from('tasks').delete().eq('client_id', id);
    await db.from('roadmap_steps').delete().eq('client_id', id);
    // Remove arquivos do storage
    const { data: docs } = await db.from('documents').select('storage_path').eq('client_id', id);
    if (docs && docs.length > 0) {
      await db.storage.from('vault').remove(docs.map((d: any) => d.storage_path));
    }
    await db.from('documents').delete().eq('client_id', id);
    await db.from('clients').delete().eq('id', id);
    return Astro.redirect('/clients');
  } else if (action === 'update-roadmap-info') {
    const title = formData.get('roadmap_title')?.toString() || 'Jornada dos 12 Checkpoints';
    const subtitle = formData.get('roadmap_subtitle')?.toString() || 'Um plano de desenvolvimento personalizado';
    await db.from('clients').update({ roadmap_title: title, roadmap_subtitle: subtitle }).eq('id', id);
  } else if (action === 'add-meeting') {
    const { data: stepData } = await db.from('roadmap_steps').select('step_number').eq('client_id', id).order('step_number', { ascending: false }).limit(1);
    const maxStep = stepData && stepData.length > 0 ? stepData[0].step_number : 0;
    
    const { error: insertError } = await db.from('roadmap_steps').insert({
      client_id: id,
      step_number: maxStep + 1,
      title: 'Novo Checkpoint',
      description: 'Descrição do novo checkpoint',
      month_label: '',
      status: maxStep === 0 ? 'current' : 'locked',
      notes: null,
      checkmarks: [],
      delivery_url: null,
    });
    if (insertError) {
      console.error("ERRO AO CRIAR CHECKPOINT:", insertError);
    }
  }

  return Astro.redirect(`/clients/${id}`);
}

// Busca steps, tasks e documentos em paralelo
const [{ data: steps = [] }, { data: allTasks = [] }, { data: documents = [] }] = await Promise.all([
  db.from('roadmap_steps').select('*').eq('client_id', id).order('step_number'),
  db.from('tasks').select('*').eq('client_id', id).order('created_at'),
  db.from('documents').select('*').eq('client_id', id).order('uploaded_at', { ascending: false }),
]);

const progress = calcProgress((steps ?? []) as RoadmapStep[]);
const baseUrl = import.meta.env.DEV ? 'http://localhost:4321' : 'https://appdoconsultor.rhconexa.com.br';
const roadmapLink = `${baseUrl}/roadmap/${client.id}`;
---

<ConsultantLayout title={`Roadmap · ${client.name}`} activePage="clients">
  <div id="client-detail-container" data-user-id={userId} class="p-4 md:p-8 animate-fade-in max-w-[100vw]">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 md:mb-8 gap-4">
      <div class="flex items-center gap-4">
        <a href="/clients" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-1">
          ← Voltar
        </a>
        <div>
          <h1 class="text-2xl font-bold text-white">{client.name}</h1>
          {client.sector && <p class="text-slate-400 text-sm mt-0.5">{client.sector}</p>}
        </div>
      </div>
      <!-- Box Progresso e Lixeira -->
      <div class="flex flex-wrap items-center gap-3">
        <div id="client-overview-progress" class="glass px-5 py-3 text-right">
          <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Progresso</p>
          <div class="flex items-center gap-3 justify-end mt-1">
            <p class="text-2xl font-bold gradient-text leading-none">{progress}%</p>
            <div class="progress-bar w-24">
              <div class="progress-fill" style={`width: ${progress}%`}></div>
            </div>
          </div>
        </div>
        <!-- Botão deletar cliente -->
        <form method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este cliente? Todos os dados serão removidos permanentemente.')">
          <input type="hidden" name="action" value="delete-client" />
          <button type="submit" class="glass h-full px-4 py-3 text-slate-600 hover:text-red-400 hover:bg-red-400/10 transition-colors flex items-center justify-center rounded-xl" title="Excluir Cliente">
            🗑️
          </button>
        </form>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
      <!-- Coluna principal: roadmap steps -->
      <div class="xl:col-span-2 space-y-3">
        <div id="client-roadmap-header" class="glass p-4 mb-4 relative group">
          <form method="POST" class="flex flex-col gap-1">
            <input type="hidden" name="action" value="update-roadmap-info" />
            <div class="flex items-start justify-between">
              <input type="text" name="roadmap_title" 
                value={client.roadmap_title || 'Jornada dos 12 Checkpoints'} 
                class="bg-transparent border-none text-2xl md:text-3xl font-bold text-white mb-1 focus:ring-0 p-0 w-full placeholder-white/30"
                placeholder="Ex: Jornada dos 12 Checkpoints"
              />
              <button type="submit" class="opacity-0 group-hover:opacity-100 text-xs px-3 py-1 bg-brand-500/20 text-brand-400 hover:bg-brand-500/40 rounded-lg transition-all flex-shrink-0 ml-2">Salvar Info</button>
            </div>
            <input 
              type="text" 
              name="roadmap_subtitle" 
              value={client.roadmap_subtitle || 'Um plano de desenvolvimento personalizado'} 
              class="bg-transparent border-none text-slate-400 text-sm p-0 focus:ring-0 w-full placeholder-slate-600 hover:bg-white/5 rounded px-2 -ml-2 transition-colors"
              placeholder="Escreva um subtítulo descritivo..."
            />
          </form>
        </div>

        {(steps as RoadmapStep[]).length === 0 ? (
          <div class="glass p-12 text-center mt-6">
            <p class="text-4xl mb-3">📋</p>
            <p class="text-slate-400 text-sm">Nenhum checkpoint encontrado para este cliente.</p>
            <p class="text-slate-600 text-xs mt-1">Crie um novo checkpoint clicando no botão abaixo.</p>
          </div>
        ) : (
          (steps as RoadmapStep[]).map((step, idx) => (
            <StepEditor
              client:load
              step={step}
              tasks={(allTasks as Task[]).filter(t => t.step_number === step.step_number)}
              isInitiallyOpen={step.status === 'current'}
              accessToken={accessToken}
              refreshToken={refreshToken}
            />
          ))
        )}

        <form method="POST" class="mt-4">
          <input type="hidden" name="action" value="add-meeting" />
          <button type="submit" id="add-first-meeting-btn" class="w-full mt-6 py-4 glass-hover flex items-center justify-center gap-2 text-brand-400 font-bold group cursor-pointer">
            <span class="w-6 h-6 rounded-full bg-brand-500/20 flex items-center justify-center group-hover:bg-brand-500/40 transition-colors">+</span>
            Adicionar Novo Checkpoint
          </button>
        </form>
      </div>

      <!-- Sidebar direita -->
      <div class="space-y-5">
        <!-- Info do Cliente -->
        <div id="client-access-card" class="glass p-5">
          <h3 class="text-white font-bold mb-4">👤 Acesso do Cliente</h3>
          <div class="space-y-3">
            <div>
              <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Email</p>
              <p class="text-slate-200 text-sm">{client.client_email}</p>
            </div>
            <div>
              <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Link do Roadmap</p>
              <p class="text-brand-400 text-xs break-all mb-2">/roadmap/{client.id}</p>
              <button
                id="copy-link-btn"
                data-link={roadmapLink}
                class="btn-ghost text-xs w-full justify-center"
              >
                <span>📋</span> Copiar Link
              </button>
            </div>
            <div>
              <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Cliente desde</p>
              <p class="text-slate-300 text-sm">{new Date(client.created_at).toLocaleDateString('pt-BR')}</p>
            </div>
            <a
              href={`/roadmap/${client.id}`}
              target="_blank"
              class="btn-ghost text-xs w-full justify-center mt-2"
            >
              <span>👁️</span> Ver como cliente
            </a>
          </div>
        </div>

        {/* Cofre de Documentos */}
        <div id="client-vault-card" class="glass p-5">
          <h3 class="text-white font-bold mb-4">🗄️ Cofre de Documentos</h3>
          
          {/* Upload de arquivos vai para o frontend para evitar PayloadTooLarge da Vercel */}
          <VaultUploader client:load clientId={id} />

          {/* Lista de documentos */}
          {documents.length === 0 ? (
            <p class="text-slate-500 text-sm py-8 text-center bg-white/5 rounded-xl border border-dashed border-white/10">Nenhum arquivo no cofre ainda.</p>
          ) : (
            <div class="space-y-2 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
              {(documents as Document[]).map((doc) => (
                <div class="flex items-center justify-between p-3 glass-hover group">
                  <div class="flex items-center gap-3 overflow-hidden">
                    <span class="text-xl opacity-70 group-hover:opacity-100 transition-all">
                      {doc.file_type?.includes('pdf') ? '📕' : doc.file_type?.includes('image') ? '🖼️' : doc.file_type?.includes('sheet') ? '📗' : '📄'}
                    </span>
                    <div class="overflow-hidden">
                      <p class="text-white text-xs font-medium truncate">{doc.name}</p>
                      <p class="text-slate-500 text-[10px] mt-0.5">
                        {doc.file_size ? `${(doc.file_size / 1024).toFixed(0)} KB · ` : ''}
                        {new Date(doc.uploaded_at).toLocaleDateString('pt-BR')}
                      </p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <a 
                      href={`/api/download?path=${doc.storage_path}`} 
                      class="p-2 hover:bg-brand-500/10 rounded-lg text-brand-400 transition-colors"
                      title="Baixar"
                    >📥</a>
                    <form method="POST">
                      <input type="hidden" name="action" value="delete-file" />
                      <input type="hidden" name="file-id" value={doc.id} />
                      <input type="hidden" name="file-path" value={doc.storage_path} />
                      <button 
                        type="submit" 
                        class="p-2 hover:bg-red-500/10 rounded-lg text-red-400/50 hover:text-red-400 transition-colors"
                        title="Remover"
                        onclick="return confirm('Tem certeza que deseja remover este arquivo?')"
                      >🗑️</button>
                    </form>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <script>
    // Copiar link do roadmap
    const copyBtn = document.getElementById('copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const link = copyBtn.getAttribute('data-link');
        if (link) {
          navigator.clipboard.writeText(link).then(() => {
            const originalHTML = copyBtn.innerHTML;
            copyBtn.innerHTML = '<span>✅</span> Link Copiado!';
            copyBtn.classList.add('text-green-400');
            setTimeout(() => {
              copyBtn.innerHTML = originalHTML;
              copyBtn.classList.remove('text-green-400');
            }, 3000);
          }).catch(() => {
            // Fallback para navegadores que não suportam clipboard API
            const el = document.createElement('textarea');
            el.value = link;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            copyBtn.innerHTML = '<span>✅</span> Copiado!'; // Mostrar notificação e sumir após 3s
            setTimeout(() => { copyBtn.innerHTML = '<span>📋</span> Copiar Link'; }, 3000);
          });
        }
      });
    }
  </script>

  <script>
    import { driver } from "driver.js";
    import "driver.js/dist/driver.css";

    const initTourDetail = () => {
      const container = document.getElementById('client-detail-container');
      const tourUserId = container?.getAttribute('data-user-id') || 'generic';
      const storageKey = `ob_client_detail_dash_${tourUserId}`;

      // O onboarding para os detalhes do cliente
      if (!localStorage.getItem(storageKey)) {
        const steps: any[] = [];
        
        steps.push({
          element: '#client-roadmap-header',
          popover: {
            title: 'Personalize o Roadmap',
            description: 'Você pode clicar nos textos aqui para editar o Título e Subtítulo visíveis para o seu cliente.',
            side: "bottom",
            align: 'start'
          }
        });

        if (document.getElementById('client-overview-progress')) {
          steps.push({
            element: '#client-overview-progress',
            popover: {
              title: 'Progresso Geral',
              description: 'Aqui você acompanha a porcentagem de evolução de todos os checkpoints abertos da empresa.',
              side: "bottom",
              align: 'end'
            }
          });
        }

        steps.push({
          element: '#add-first-meeting-btn',
          popover: {
            title: 'Crie seu 1º Checkpoint',
            description: 'Para iniciar a jornada, adicione o primeiro checkpoint. Dentro dele você poderá criar tarefas, colocar notas e anexos.',
            side: "top",
            align: 'center'
          }
        });

        if (document.getElementById('client-access-card')) {
          steps.push({
            element: '#client-access-card',
            popover: {
              title: 'Acesso Exclusivo',
              description: 'Clique em "Copiar Link" e envie para o cliente. Quando ele acessar, verá um painel incrível para acompanhar o projeto (sem edição).',
              side: "left",
              align: 'start'
            }
          });
        }

        if (document.getElementById('client-vault-card')) {
          steps.push({
            element: '#client-vault-card',
            popover: {
              title: 'Cofre e Materiais',
              description: 'Envie planilhas, PDFs e materiais por aqui. Tudo fica salvo e organizado no cofre digital do cliente.',
              side: "left",
              align: 'start'
            }
          });
        }

        const driverObj = driver({
          showProgress: true,
          nextBtnText: 'Próximo →',
          prevBtnText: '← Anterior',
          doneBtnText: 'Entendi!',
          steps: steps,
          onDestroyStarted: () => {
            if (!driverObj.hasNextStep() || confirm("Deseja pular as dicas?")) {
              localStorage.setItem(storageKey, 'true');
              driverObj.destroy();
            }
          },
        });

        setTimeout(() => driverObj.drive(), 500);
      }
    };

    initTourDetail();
    document.addEventListener('astro:page-load', initTourDetail);
  </script>
</ConsultantLayout>
